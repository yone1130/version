{
    "compilerOptions": {
        "target": "ESNext",
        "strict": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "rootDir": "./src/",
        "outDir": "./dist/",
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "sourceMap": true
    }
}
